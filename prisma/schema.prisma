generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  name      String
  role      UserRole @default(MEMBER)
  signature String?
  roles     String[] @default([])
  section   OrdemSection?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  meetings         Meeting[]
  meetingAttendees MeetingAttendee[]
  scoutProfile     Scout?
  scoutLeaders     ScoutLeader[]
  documents        Document[]
  signedDocuments  Document[] @relation("DocumentSignedBy")
  ordemItems       OrdemItem[]

  @@map("profiles")
}

model MeetingType {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  meetings Meeting[]

  @@map("meeting_types")
}

model Meeting {
  id          String       @id @default(cuid())
  identifier  String       @unique
  date        DateTime
  startTime   String?
  endTime     String?
  location    String?
  agenda      Json
  content     String
  decisions   Json?
  actionItems Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Full-text search
  contentTsvector Unsupported("tsvector")?

  // Relations
  meetingTypeId String
  meetingType   MeetingType @relation(fields: [meetingTypeId], references: [id])
  createdById   String
  createdBy     Profile     @relation(fields: [createdById], references: [id])
  attendees     MeetingAttendee[]

  @@map("meetings")
  @@index([contentTsvector], type: Gin)
}

model MeetingAttendee {
  id        String   @id @default(cuid())
  present   Boolean  @default(true)
  role      String?
  createdAt DateTime @default(now())

  // Relations
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  @@unique([meetingId, profileId])
  @@map("meeting_attendees")
}

model Scout {
  id                    String        @id @default(cuid())
  profileId             String?       @unique
  firstName             String
  lastName              String
  numeroAssociado       String?       @unique
  dateOfBirth           DateTime
  section               OrdemSection?
  sexo                  String?
  cc                    String?
  nif                   String?
  email                 String?
  telefone              String?
  telemovel             String?
  morada                String?
  localidade            String?
  codigoPostal          String?
  paiNome               String?
  paiTelefone           String?
  paiEmail              String?
  maeNome               String?
  maeTelefone           String?
  maeEmail              String?
  encarregadoNome       String?
  encarregadoTelefone   String?
  encarregadoEmail      String?
  joinedAt              DateTime      @default(now())
  active                Boolean       @default(true)
  noitesCampoInicial    Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  profile      Profile?            @relation(fields: [profileId], references: [id], onDelete: SetNull)
  leaders      ScoutLeader[]
  nightsBadges ScoutNightsBadge[]

  @@map("scouts")
}

model ScoutNightsBadge {
  id        String   @id @default(cuid())
  scoutId   String
  count     Int
  awardedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scout Scout @relation(fields: [scoutId], references: [id], onDelete: Cascade)

  @@unique([scoutId, count])
  @@index([awardedAt])
  @@map("scout_nights_badges")
}

model ScoutLeader {
  id         String   @id @default(cuid())
  scoutId    String
  leaderId   String
  assignedAt DateTime @default(now())

  // Relations
  scout  Scout   @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  leader Profile @relation(fields: [leaderId], references: [id], onDelete: Cascade)

  @@unique([scoutId, leaderId])
  @@map("scout_leaders")
}

enum OrdemSection {
  ALCATEIA
  EXPEDICAO
  COMUNIDADE
  CLA
}

enum UserRole {
  ADMIN
  LEADER
  MEMBER
}

enum DocumentType {
  OFICIO
  CIRCULAR
  ORDEM_SERVICO
}

model Document {
  id          String       @id @default(cuid())
  type        DocumentType
  number      Int
  year        Int?
  content     String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  createdById String
  createdBy   Profile      @relation(fields: [createdById], references: [id])

  signedById  String?
  signedBy    Profile?     @relation("DocumentSignedBy", fields: [signedById], references: [id])
  signedAt    DateTime?

  sourceItems OrdemItem[]  @relation("OrdemItemsForOs")

  @@map("documents")
}

model DocumentSequence {
  id            String       @id @default(cuid())
  type          DocumentType
  year          Int          @default(0)  // 0 = sentinel for ORDEM_SERVICO (no year reset)
  currentNumber Int          @default(1)

  @@unique([type, year])
  @@map("document_sequences")
}

model DocumentSettings {
  type           DocumentType @id
  startingNumber Int          @default(1)

  @@map("document_settings")
}

model OrdemItem {
  id              String        @id @default(cuid())
  externalId      String?       @unique
  category        String
  section         OrdemSection?
  date            DateTime
  data            Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String
  createdBy       Profile       @relation(fields: [createdById], references: [id])

  includedInOsId  String?
  includedInOs    Document?     @relation("OrdemItemsForOs", fields: [includedInOsId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([section, category, date])
  @@index([includedInOsId])
  @@map("ordem_items")
}
