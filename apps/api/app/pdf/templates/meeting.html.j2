<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <style>
    @font-face { font-family: 'Lato'; src: url('fonts/Lato-Regular.ttf'); }
    @font-face { font-family: 'Lato'; src: url('fonts/Lato-Bold.ttf'); font-weight: bold; }

    @page {
      size: a4;
      margin: 0;
      @frame header_frame { -pdf-frame-content: headerContent; left: 2cm; top: 1cm; width: 17cm; height: 2.2cm; }
      @frame content_frame { left: 2cm; top: 3.4cm; width: 17cm; height: 24cm; }
      @frame footer_frame { -pdf-frame-content: footerContent; left: 2cm; top: 27.7cm; width: 17cm; height: 1cm; }
    }
    body { font-family: 'Lato'; font-size: 12px; line-height: 1.5; color: #333; }

    /* repeating header / footer */
    .header-table { width: 100%; }
    .header-logo { width: 64px; }
    .header-logo img { width: 60px; height: 60px; }
    .header-center { text-align: center; }
    .header-center strong { font-size: 15px; color: #1e40af; }
    .header-center span { font-size: 11px; color: #555; }
    .footer-text { text-align: center; font-size: 8px; color: #666; }

    /* content */
    .content { padding: 0; }
    h1 { color: #1e40af; text-align: center; margin-bottom: 24px; font-size: 22px; border-bottom: 3px solid #1e40af; padding-bottom: 8px; }
    h2 { color: #1e40af; margin-top: 24px; margin-bottom: 12px; font-size: 16px; border-left: 4px solid #1e40af; padding-left: 8px; }
    h3 { color: #374151; margin-top: 16px; margin-bottom: 8px; font-size: 14px; }
    .meeting-info { background: #f8fafc; padding: 14px; margin-bottom: 20px; border-left: 4px solid #1e40af; }
    .meeting-info-table { width: 100%; }
    .meeting-info-table td { width: 50%; vertical-align: top; }
    .info-item { margin-bottom: 6px; }
    .info-label { font-weight: bold; color: #374151; }
    .agenda-item { background: #f0f9ff; padding: 12px; margin-bottom: 8px; border-left: 4px solid #3b82f6; }
    .agenda-item h4 { margin: 0 0 4px 0; color: #1e40af; }
    .agenda-item p { margin: 0; color: #6b7280; font-size: 13px; }
    .action-item { background: #fff7ed; padding: 12px; margin-bottom: 8px; border-left: 4px solid #f59e0b; }
    .action-item h4 { margin: 0 0 4px 0; color: #d97706; }
    .action-details { font-size: 11px; color: #6b7280; margin-top: 4px; }
    .attendees { margin-top: 6px; }
    .attendee-tag { display: inline-block; background: #e5e7eb; color: #374151; font-size: 11px; padding: 3px 7px; margin: 0 4px 4px 0; }
    .content-section { padding: 0; margin: 10px 0 10px 12px; }
    .content-section ul, .content-section ol { margin: 8px 0; padding-left: 22px; }
    .page-break { page-break-before: always; }
    .content table { width: 100%; border-collapse: collapse; margin: 12px 0; }
    .content th, .content td { border: 1px solid #e5e7eb; padding: 6px 10px; text-align: left; }
    .content th { background: #f8fafc; font-weight: bold; color: #374151; }
  </style>
</head>
<body>
  <div id="headerContent">
    <table class="header-table">
      <tr>
        <td class="header-logo">{% if left_img %}<img src="{{ left_img }}" />{% endif %}</td>
        <td class="header-center">
          <strong>{{ line1 }}</strong><br/>
          <span>{{ line2 }}</span>
        </td>
        <td class="header-logo">{% if right_img %}<img src="{{ right_img }}" />{% endif %}</td>
      </tr>
    </table>
  </div>
  <div id="footerContent">
    <div class="footer-text">CNE - instituição de utilidade pública &nbsp;·&nbsp; Página <pdf:pagenumber /> de <pdf:pagecount /></div>
  </div>
  {{ body }}
</body>
</html>
