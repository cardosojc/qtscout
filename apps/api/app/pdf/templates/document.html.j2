<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <style>
    @font-face { font-family: 'Lato'; src: url('fonts/Lato-Regular.ttf'); }
    @font-face { font-family: 'Lato'; src: url('fonts/Lato-Bold.ttf'); font-weight: bold; }
    @font-face { font-family: 'Caveat'; src: url('fonts/Caveat-Regular.ttf'); }

    /* xhtml2pdf pagination: content flows in the @page MARGIN box; the header/
       footer are static @frames that repeat per page. Do NOT add a content
       @frame — an explicit content frame breaks overflow (content piles up and
       overlaps on one page instead of breaking). Units in pt (cm is mis-parsed).
       A4 = 595x842pt; ~2cm side margins. */
    @page {
      size: a4 portrait;
      margin: 96pt 57pt 50pt 57pt;
      @frame header_frame { -pdf-frame-content: headerContent; left: 57pt; top: 28pt; width: 481pt; height: 62pt; }
      @frame footer_frame { -pdf-frame-content: footerContent; left: 57pt; top: 800pt; width: 481pt; height: 22pt; }
    }
    body { font-family: 'Lato'; font-size: 13px; line-height: 1.6; color: #333; }

    /* repeating header / footer */
    .header-table { width: 100%; }
    .header-logo { width: 64px; }
    .header-logo img { width: 60px; height: 60px; }
    .header-center { text-align: center; }
    .header-center strong { font-size: 15px; color: #1e40af; }
    .header-center span { font-size: 11px; color: #555; }
    .footer-text { text-align: center; font-size: 8px; color: #666; }

    /* document meta */
    .doc-meta-table { width: 100%; margin-bottom: 16px; border-bottom: 2px solid #1e40af; }
    .doc-meta-table td { padding-bottom: 10px; vertical-align: bottom; }
    .doc-identifier { font-size: 22px; font-weight: bold; color: #1e40af; }
    .doc-type-badge { background: #dbeafe; color: #1e40af; font-size: 11px; font-weight: bold; padding: 2px 8px; }
    .doc-info-line { font-size: 11px; color: #6b7280; text-align: right; }

    /* lists: xhtml2pdf only draws markers when list-style-type is explicit.
       Base rule covers the OS body (bare inline-styled <ul>); .doc-content
       rules add spacing/nesting for TipTap-authored ofício/circular bodies. */
    ul, ol { list-style-type: disc; }
    ol { list-style-type: decimal; }
    ul ul { list-style-type: circle; }

    /* document body */
    .doc-content { margin-top: 16px; line-height: 1.7; }
    .doc-content p { margin: 8px 0; }
    .doc-content h1, .doc-content h2, .doc-content h3 { color: #1e40af; margin: 16px 0 8px 0; }
    .doc-content ul, .doc-content ol { margin: 8px 0 8px 22px; padding-left: 0; }
    .doc-content ul ul, .doc-content ul ol,
    .doc-content ol ul, .doc-content ol ol { margin-top: 4px; margin-bottom: 4px; }
    .doc-content li { margin: 4px 0; }
    .doc-content li p { margin: 0; }
    .doc-content strong { font-weight: bold; }
    .doc-content em { font-style: italic; }

    /* signature */
    .doc-signature { margin-top: 48px; text-align: center; }
    .signature-greeting { font-size: 13px; color: #1f2937; margin: 0 0 12px 0; }
    .signature-img { width: 180px; margin-bottom: 4px; }
    .signature-handwritten { font-family: 'Caveat'; font-size: 28px; color: #1f2937; margin: 0 0 4px 0; }
    .signature-name { font-size: 12px; color: #1f2937; margin: 0; }
  </style>
</head>
<body>
  <div id="headerContent">
    <table class="header-table">
      <tr>
        <td class="header-logo">{% if left_img %}<img src="{{ left_img }}" />{% endif %}</td>
        <td class="header-center">
          <strong>{{ line1 }}</strong><br/>
          <span>{{ line2 }}</span>
        </td>
        <td class="header-logo">{% if right_img %}<img src="{{ right_img }}" />{% endif %}</td>
      </tr>
    </table>
  </div>
  <div id="footerContent">
    <div class="footer-text">CNE - instituição de utilidade pública &nbsp;·&nbsp; Página <pdf:pagenumber /> de <pdf:pagecount /></div>
  </div>

  <table class="doc-meta-table">
    <tr>
      <td>
        <span class="doc-identifier">{{ identifier }}</span>
        &nbsp;<span class="doc-type-badge">{{ type_label }}</span>
      </td>
      <td class="doc-info-line">{{ created_at }} &nbsp;·&nbsp; {{ created_by_name }}</td>
    </tr>
  </table>
  {{ body_content }}
  {{ signature_block }}
</body>
</html>
