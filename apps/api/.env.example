# Copy to .env and fill in. Values mirror the Hono API's env (apps/web/.env.local).

# Supabase Postgres. DATABASE_URL = pooler (transaction mode); DIRECT_URL = direct (Alembic).
DATABASE_URL=postgresql://user:pass@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:pass@host:5432/postgres

# Supabase auth.
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<anon/publishable key>
SUPABASE_SECRET_KEY=<service-role/secret key>
# Offline JWT verification via Supabase JWKS (ES256) is ON by default and skips
# the per-request GET /auth/v1/user network call. Set false to force the API path.
# JWT_LOCAL_VERIFY=true

# AI (rich-text editor features).
MISTRAL_API_KEY=<key>

# PDF rendering. Leave unset to launch Chromium locally (Railway's Docker image
# bundles it). Set to a remote Chromium CDP endpoint (e.g. Browserless) on hosts
# that can't bundle Chromium + system libs, such as FastAPI Cloud.
# BROWSER_WS_URL=wss://chrome.browserless.io?token=<token>

# CORS — comma-separated web origins.
WEB_ORIGIN=http://localhost:3000

# Local dev port.
PORT=3001
