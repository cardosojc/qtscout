{
  "name": "qtscout",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docs:sync": "tsx scripts/sync-categories-doc.ts",
    "docs:check": "tsx scripts/sync-categories-doc.ts --check",
    "sync:categories": "node scripts/sync-categories.mjs",
    "sync:categories:check": "node scripts/sync-categories.mjs --check",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "dotenv": "^17.3.1",
    "tsx": "^4.20.5",
    "turbo": "^2.3.3",
    "typescript": "^5"
  }
}
